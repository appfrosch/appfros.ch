# Public Supabase config for the beta-signup form (TestFlightCTA.astro).
# These are PUBLIC by design — the publishable key is the same one shipped in
# the RoadTrippin app, and the `testflight_signups` table is insert-only (RLS),
# so this key can add signups but cannot read them. Copy this file to `.env`
# (git-ignored) for local dev, and set the same vars in your deploy host.
PUBLIC_SUPABASE_URL=https://rdkdeadhpwotpwktegpy.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_kWnhqHZXVm30ZHxZMC0HBA_crMX5-pC
