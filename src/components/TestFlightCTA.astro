---
// Beta-testing alert + email signup, rendered at the top of a work page when `beta: true`.
// We collect interested testers' emails (we reach out with invites) rather than letting
// people self-enroll. The form posts straight to Supabase (insert-only RLS), so no server
// is needed.
//
// Visible copy and the client-side status messages are localized here. The messages used
// by the inline client script are passed via data-* attributes, since that script is
// bundled separately and can't read these frontmatter variables directly.
import type { Lang } from '../i18n/ui';

interface Props {
	lang?: Lang;
}

const { lang = 'en' } = Astro.props;

const copy = {
	en: {
		badge: '🧪 Now in beta',
		title: 'RoadTrippin is in beta testing',
		lead: "The app isn't on the App Store or Google Play yet — it's being tested through Apple TestFlight and Google Play testing. Want to help test it? Leave your email and we'll reach out with an invite.",
		legend: 'Which beta(s) are you interested in?',
		android: 'Android (Play testing)',
		emailLabel: 'Your email',
		placeholder: 'you@example.com',
		submit: 'Notify me',
		invalid: 'Please enter a valid email address.',
		platform: 'Please choose at least one platform — iOS, Android, or both.',
		unconfigured: "Signups aren't configured yet — please email splash@appfros.ch.",
		saving: 'Saving…',
		ok: "You're on the list — we'll be in touch. Thanks! 🎉",
		dupe: "You're already on the list — sit tight! 🙌",
		error: 'Something went wrong. Please try again, or email splash@appfros.ch.',
		network: 'Network error. Please check your connection and try again.',
	},
	de: {
		badge: '🧪 Jetzt in der Beta',
		title: 'RoadTrippin ist in der Beta-Testphase',
		lead: 'Die App ist noch nicht im App Store oder bei Google Play — sie wird über Apple TestFlight und Google-Play-Tests getestet. Möchtest du mittesten? Hinterlass deine E-Mail und wir melden uns mit einer Einladung.',
		legend: 'Für welche Beta(s) interessierst du dich?',
		android: 'Android (Play-Test)',
		emailLabel: 'Deine E-Mail',
		placeholder: 'du@beispiel.ch',
		submit: 'Benachrichtige mich',
		invalid: 'Bitte gib eine gültige E-Mail-Adresse ein.',
		platform: 'Bitte wähle mindestens eine Plattform — iOS, Android oder beide.',
		unconfigured: 'Die Anmeldung ist noch nicht eingerichtet — bitte schreib an splash@appfros.ch.',
		saving: 'Wird gespeichert …',
		ok: 'Du bist auf der Liste — wir melden uns. Danke! 🎉',
		dupe: 'Du bist bereits auf der Liste — bleib dran! 🙌',
		error: 'Etwas ist schiefgelaufen. Bitte versuch es erneut oder schreib an splash@appfros.ch.',
		network: 'Netzwerkfehler. Bitte überprüfe deine Verbindung und versuch es erneut.',
	},
}[lang];
---

<section class="beta-cta" aria-labelledby="beta-cta-title">
	<div class="badge">{copy.badge}</div>
	<h2 id="beta-cta-title">{copy.title}</h2>
	<p class="lead">{copy.lead}</p>

	<form
		class="signup"
		id="beta-signup"
		novalidate
		data-msg-invalid={copy.invalid}
		data-msg-platform={copy.platform}
		data-msg-unconfigured={copy.unconfigured}
		data-msg-saving={copy.saving}
		data-msg-ok={copy.ok}
		data-msg-dupe={copy.dupe}
		data-msg-error={copy.error}
		data-msg-network={copy.network}
	>
		<fieldset class="platforms">
			<legend class="field-label">{copy.legend}</legend>
			<label class="check">
				<input type="checkbox" id="want-ios" name="ios" /> iOS (TestFlight)
			</label>
			<label class="check">
				<input type="checkbox" id="want-android" name="android" /> {copy.android}
			</label>
		</fieldset>
		<label class="field-label" for="beta-email">{copy.emailLabel}</label>
		<div class="row">
			<input
				type="email"
				id="beta-email"
				name="email"
				inputmode="email"
				autocomplete="email"
				placeholder={copy.placeholder}
				required
			/>
			<button type="submit" id="beta-submit">{copy.submit}</button>
		</div>
		<p class="form-status" id="beta-status" role="status" aria-live="polite"></p>
	</form>
</section>

<script>
	const url = import.meta.env.PUBLIC_SUPABASE_URL;
	const key = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

	const form = document.getElementById('beta-signup') as HTMLFormElement | null;
	const input = document.getElementById('beta-email') as HTMLInputElement | null;
	const iosBox = document.getElementById('want-ios') as HTMLInputElement | null;
	const androidBox = document.getElementById('want-android') as HTMLInputElement | null;
	const button = document.getElementById('beta-submit') as HTMLButtonElement | null;
	const status = document.getElementById('beta-status');

	// Localized status messages are provided by the server-rendered form via data-* attributes.
	const msg = (name: string, fallback: string) => form?.dataset[name] ?? fallback;

	function setStatus(message: string, kind: 'ok' | 'error' | '') {
		if (!status) return;
		status.textContent = message;
		status.dataset.kind = kind;
	}

	form?.addEventListener('submit', async (event) => {
		event.preventDefault();
		if (!input || !button) return;

		const email = input.value.trim();
		if (!email || !input.checkValidity()) {
			setStatus(msg('msgInvalid', 'Please enter a valid email address.'), 'error');
			input.focus();
			return;
		}

		const wantsIos = !!iosBox?.checked;
		const wantsAndroid = !!androidBox?.checked;
		if (!wantsIos && !wantsAndroid) {
			setStatus(msg('msgPlatform', 'Please choose at least one platform — iOS, Android, or both.'), 'error');
			return;
		}

		if (!url || !key) {
			setStatus(msg('msgUnconfigured', "Signups aren't configured yet — please email splash@appfros.ch."), 'error');
			return;
		}

		button.disabled = true;
		setStatus(msg('msgSaving', 'Saving…'), '');

		try {
			const res = await fetch(`${url}/rest/v1/testflight_signups`, {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
					apikey: key,
					Authorization: `Bearer ${key}`,
					Prefer: 'return=minimal',
				},
				body: JSON.stringify({ email, wants_ios: wantsIos, wants_android: wantsAndroid }),
			});

			if (res.ok) {
				form.reset();
				setStatus(msg('msgOk', "You're on the list — we'll be in touch. Thanks! 🎉"), 'ok');
			} else if (res.status === 409) {
				// Unique-index violation: this email is already signed up.
				setStatus(msg('msgDupe', "You're already on the list — sit tight! 🙌"), 'ok');
			} else {
				setStatus(msg('msgError', 'Something went wrong. Please try again, or email splash@appfros.ch.'), 'error');
			}
		} catch {
			setStatus(msg('msgNetwork', 'Network error. Please check your connection and try again.'), 'error');
		} finally {
			button.disabled = false;
		}
	});
</script>

<style>
	.beta-cta {
		padding: 1.5rem;
		border: 1px solid var(--accent-regular);
		border-radius: 1.5rem;
		background: var(--gradient-subtle);
		box-shadow: var(--shadow-sm);
	}

	.badge {
		display: inline-flex;
		padding: 0.35rem 0.85rem;
		margin-bottom: 0.75rem;
		color: var(--accent-text-over);
		background-color: var(--accent-regular);
		border-radius: 999rem;
		font-size: var(--text-sm);
		font-weight: 600;
	}

	.beta-cta h2 {
		margin: 0 0 0.5rem;
		font-size: var(--text-xl);
	}

	.lead {
		margin: 0 0 1.5rem;
		color: var(--gray-300);
		max-width: 60ch;
	}

	.field-label {
		display: block;
		margin-bottom: 0.5rem;
		font-size: var(--text-sm);
		color: var(--gray-300);
	}

	.platforms {
		margin: 0 0 1rem;
		padding: 0;
		border: 0;
	}

	.check {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		margin-right: 1.25rem;
		color: var(--gray-200);
		cursor: pointer;
	}

	.check input {
		width: 1.1rem;
		height: 1.1rem;
		accent-color: var(--accent-regular);
		cursor: pointer;
	}

	.row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}

	.row input {
		flex: 1 1 16rem;
		min-width: 0;
		padding: 0.65rem 0.9rem;
		font: inherit;
		color: var(--gray-0);
		background-color: var(--gray-999);
		border: 1px solid var(--gray-700);
		border-radius: 0.75rem;
	}

	.row input:focus {
		outline: 2px solid var(--accent-regular);
		outline-offset: 1px;
	}

	.row button {
		padding: 0.65rem 1.4rem;
		font: inherit;
		font-weight: 600;
		color: var(--accent-text-over);
		background: var(--gradient-accent-orange);
		border: none;
		border-radius: 0.75rem;
		cursor: pointer;
		box-shadow: var(--shadow-sm);
		transition: filter var(--theme-transition);
	}

	.row button:hover:not(:disabled),
	.row button:focus:not(:disabled) {
		filter: brightness(1.08);
	}

	.row button:disabled {
		opacity: 0.6;
		cursor: progress;
	}

	.form-status {
		margin: 0.75rem 0 0;
		min-height: 1.25rem;
		font-size: var(--text-sm);
	}

	.form-status[data-kind='ok'] {
		color: var(--accent-dark);
	}

	.form-status[data-kind='error'] {
		color: #d73a4a;
	}

	@media (min-width: 50em) {
		.beta-cta {
			padding: 2rem;
		}
		.beta-cta h2 {
			font-size: var(--text-2xl);
		}
	}
</style>
