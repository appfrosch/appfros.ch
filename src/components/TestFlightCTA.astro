---
// Beta-testing alert + enrollment CTA, rendered at the top of a work page when `beta: true`.
// The email form posts straight to Supabase (insert-only RLS), so no server is needed.
interface Props {
	/** Apple TestFlight public link, e.g. https://testflight.apple.com/join/XXXXXXXX */
	testflightUrl?: string;
	/** Google Play closed/open-testing opt-in URL. Button is shown as "coming soon" when absent. */
	androidTestUrl?: string;
}

const { testflightUrl, androidTestUrl } = Astro.props;
---

<section class="beta-cta" aria-labelledby="beta-cta-title">
	<div class="badge">🧪 Now in beta</div>
	<h2 id="beta-cta-title">RoadTrippin is in public beta testing</h2>
	<p class="lead">
		The app isn't on the App Store or Google Play yet — it's being tested through
		Apple TestFlight and Google Play testing. Want an early look? Join a beta below,
		or leave your email and we'll reach out with an invite.
	</p>

	<div class="enroll">
		{testflightUrl ? (
			<a class="btn btn-primary" href={testflightUrl} target="_blank" rel="noopener noreferrer">
				 Join the iOS beta (TestFlight)
			</a>
		) : (
			<span class="btn btn-disabled" aria-disabled="true"> iOS beta — link coming soon</span>
		)}

		{androidTestUrl ? (
			<a class="btn btn-primary" href={androidTestUrl} target="_blank" rel="noopener noreferrer">
				▶ Join the Android beta
			</a>
		) : (
			<span class="btn btn-disabled" aria-disabled="true">▶ Android beta — coming soon</span>
		)}
	</div>

	<form class="signup" id="beta-signup" novalidate>
		<label class="field-label" for="beta-email">Or get notified when there's a spot</label>
		<div class="row">
			<input
				type="email"
				id="beta-email"
				name="email"
				inputmode="email"
				autocomplete="email"
				placeholder="you@example.com"
				required
			/>
			<button type="submit" id="beta-submit">Keep me posted</button>
		</div>
		<p class="form-status" id="beta-status" role="status" aria-live="polite"></p>
	</form>
</section>

<script>
	const url = import.meta.env.PUBLIC_SUPABASE_URL;
	const key = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

	const form = document.getElementById('beta-signup') as HTMLFormElement | null;
	const input = document.getElementById('beta-email') as HTMLInputElement | null;
	const button = document.getElementById('beta-submit') as HTMLButtonElement | null;
	const status = document.getElementById('beta-status');

	function setStatus(message: string, kind: 'ok' | 'error' | '') {
		if (!status) return;
		status.textContent = message;
		status.dataset.kind = kind;
	}

	form?.addEventListener('submit', async (event) => {
		event.preventDefault();
		if (!input || !button) return;

		const email = input.value.trim();
		if (!email || !input.checkValidity()) {
			setStatus('Please enter a valid email address.', 'error');
			input.focus();
			return;
		}

		if (!url || !key) {
			setStatus("Signups aren't configured yet — please email splash@appfros.ch.", 'error');
			return;
		}

		button.disabled = true;
		setStatus('Saving…', '');

		try {
			const res = await fetch(`${url}/rest/v1/testflight_signups`, {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
					apikey: key,
					Authorization: `Bearer ${key}`,
					Prefer: 'return=minimal',
				},
				body: JSON.stringify({ email }),
			});

			if (res.ok) {
				form.reset();
				setStatus("You're on the list — we'll be in touch. Thanks! 🎉", 'ok');
			} else if (res.status === 409) {
				// Unique-index violation: this email is already signed up.
				setStatus("You're already on the list — sit tight! 🙌", 'ok');
			} else {
				setStatus('Something went wrong. Please try again, or email splash@appfros.ch.', 'error');
			}
		} catch {
			setStatus('Network error. Please check your connection and try again.', 'error');
		} finally {
			button.disabled = false;
		}
	});
</script>

<style>
	.beta-cta {
		padding: 1.5rem;
		border: 1px solid var(--accent-regular);
		border-radius: 1.5rem;
		background: var(--gradient-subtle);
		box-shadow: var(--shadow-sm);
	}

	.badge {
		display: inline-flex;
		padding: 0.35rem 0.85rem;
		margin-bottom: 0.75rem;
		color: var(--accent-text-over);
		background-color: var(--accent-regular);
		border-radius: 999rem;
		font-size: var(--text-sm);
		font-weight: 600;
	}

	.beta-cta h2 {
		margin: 0 0 0.5rem;
		font-size: var(--text-xl);
	}

	.lead {
		margin: 0 0 1.25rem;
		color: var(--gray-300);
		max-width: 60ch;
	}

	.enroll {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-bottom: 1.5rem;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
		padding: 0.6em 1.25em;
		border-radius: 999rem;
		font-size: var(--text-md);
		line-height: 1.1;
		text-decoration: none;
		white-space: nowrap;
	}

	.btn-primary {
		color: var(--accent-text-over);
		background: var(--gradient-accent-orange);
		box-shadow: var(--shadow-sm);
		transition: filter var(--theme-transition);
	}

	.btn-primary:hover,
	.btn-primary:focus {
		filter: brightness(1.08);
	}

	.btn-disabled {
		color: var(--gray-400);
		background-color: var(--gray-800);
		border: 1px solid var(--gray-700);
		cursor: not-allowed;
	}

	.signup {
		border-top: 1px solid var(--gray-800);
		padding-top: 1.25rem;
	}

	.field-label {
		display: block;
		margin-bottom: 0.5rem;
		font-size: var(--text-sm);
		color: var(--gray-300);
	}

	.row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}

	.row input {
		flex: 1 1 16rem;
		min-width: 0;
		padding: 0.65rem 0.9rem;
		font: inherit;
		color: var(--gray-0);
		background-color: var(--gray-999);
		border: 1px solid var(--gray-700);
		border-radius: 0.75rem;
	}

	.row input:focus {
		outline: 2px solid var(--accent-regular);
		outline-offset: 1px;
	}

	.row button {
		padding: 0.65rem 1.4rem;
		font: inherit;
		font-weight: 600;
		color: var(--accent-text-over);
		background: var(--gradient-accent-orange);
		border: none;
		border-radius: 0.75rem;
		cursor: pointer;
		box-shadow: var(--shadow-sm);
		transition: filter var(--theme-transition);
	}

	.row button:hover:not(:disabled),
	.row button:focus:not(:disabled) {
		filter: brightness(1.08);
	}

	.row button:disabled {
		opacity: 0.6;
		cursor: progress;
	}

	.form-status {
		margin: 0.75rem 0 0;
		min-height: 1.25rem;
		font-size: var(--text-sm);
	}

	.form-status[data-kind='ok'] {
		color: var(--accent-dark);
	}

	.form-status[data-kind='error'] {
		color: #d73a4a;
	}

	@media (min-width: 50em) {
		.beta-cta {
			padding: 2rem;
		}
		.beta-cta h2 {
			font-size: var(--text-2xl);
		}
	}
</style>
