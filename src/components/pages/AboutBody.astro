---
import { getEntry, render } from 'astro:content';
import Hero from '../Hero.astro';
import type { Lang } from '../../i18n/ui';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const about = await getEntry('pages', `${lang}/about`);
if (!about) throw new Error(`Missing about page for locale "${lang}"`);
const { Content } = await render(about);
const { tagline } = about.data;
---

<div class="stack gap-20">
	<main class="wrapper about">
		<Hero title={about.data.title} tagline={tagline} />
		<div class="content">
			<Content />
		</div>
	</main>
</div>

<style>
	.about {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
	}

	.content {
		max-width: 65ch;
		margin-inline: auto;
		color: var(--gray-200);
	}

	.content > :global(* + *) {
		margin-top: 1rem;
	}

	.content :global(h2) {
		position: relative;
		margin: 1.5rem 0 0.5rem;
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	.content :global(.anchor-link) {
		opacity: 0;
		margin-left: 0.4em;
		font-size: 0.85em;
		text-decoration: none;
		color: var(--gray-400);
		transition: opacity var(--theme-transition);
	}

	.content :global(h2:hover .anchor-link) {
		opacity: 1;
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.content {
			font-size: var(--text-lg);
		}
	}
</style>
