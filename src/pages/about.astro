---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import AboutBody from '../components/pages/AboutBody.astro';

const about = await getEntry('pages', 'en/about');
const { title, description } = about!.data;
---

<BaseLayout title={`${title} | Appfrosch`} description={description} lang="en">
	<AboutBody lang="en" />
</BaseLayout>
