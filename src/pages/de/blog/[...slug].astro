---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogArticle from '../../../components/BlogArticle.astro';
import { localeOf, slugOf } from '../../../i18n/ui';

interface Props {
	entry: CollectionEntry<'blog'>;
}

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts
		.filter((entry) => localeOf(entry.id) === 'de')
		.map((entry) => ({
			params: { slug: slugOf(entry.id) },
			props: { entry },
		}));
}

const { entry } = Astro.props;
---

<BaseLayout title={entry.data.title} description={entry.data.description} lang="de">
	<BlogArticle entry={entry} lang="de" />
</BaseLayout>
