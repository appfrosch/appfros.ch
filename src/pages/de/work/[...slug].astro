---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import WorkArticle from '../../../components/WorkArticle.astro';
import { localeOf, slugOf } from '../../../i18n/ui';

interface Props {
	entry: CollectionEntry<'work'>;
}

export async function getStaticPaths() {
	const work = await getCollection('work');
	return work
		.filter((entry) => localeOf(entry.id) === 'de')
		.map((entry) => ({
			params: { slug: slugOf(entry.id) },
			props: { entry },
		}));
}

const { entry } = Astro.props;
---

<BaseLayout title={entry.data.title} description={entry.data.description} lang="de">
	<WorkArticle entry={entry} lang="de" />
</BaseLayout>
