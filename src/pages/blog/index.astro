---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);

const formatDate = (date: Date) =>
	date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title="Blog | Appfrosch" description="Thoughts on development, indie apps, and the journey.">
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="Blog"
				tagline="Thoughts on development, indie apps, and the journey."
				align="start"
			/>
			<ul class="post-list">
				{
					posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`} class="post-link">
								<h2 class="post-title">{post.data.title}</h2>
								<p class="post-date">{formatDate(post.data.publishDate)}</p>
								<p class="post-description">{post.data.description}</p>
							</a>
						</li>
					))
				}
			</ul>
		</main>
	</div>
</BaseLayout>

<style>
	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.post-link {
		display: block;
		text-decoration: none;
		padding: 1.5rem;
		border: 1px solid var(--gray-800);
		border-radius: 1rem;
		background: var(--gradient-subtle);
		box-shadow: var(--shadow-sm);
		transition:
			border-color var(--theme-transition),
			box-shadow var(--theme-transition);
	}

	.post-link:hover,
	.post-link:focus {
		border-color: var(--accent-regular);
		box-shadow: var(--shadow-md);
	}

	.post-title {
		font-size: var(--text-xl);
		color: var(--gray-0);
		margin: 0 0 0.25rem;
	}

	.post-date {
		font-size: var(--text-sm);
		color: var(--gray-400);
		margin: 0 0 0.75rem;
	}

	.post-description {
		font-size: var(--text-md);
		color: var(--gray-300);
		margin: 0;
	}
</style>
