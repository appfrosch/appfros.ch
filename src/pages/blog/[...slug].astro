---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogArticle from '../../components/BlogArticle.astro';
import { localeOf, slugOf } from '../../i18n/ui';

interface Props {
	entry: CollectionEntry<'blog'>;
}

// One page per English blog entry. German entries are handled by src/pages/de/blog/[...slug].astro.
export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts
		.filter((entry) => localeOf(entry.id) === 'en')
		.map((entry) => ({
			params: { slug: slugOf(entry.id) },
			props: { entry },
		}));
}

const { entry } = Astro.props;
---

<BaseLayout title={entry.data.title} description={entry.data.description} lang="en">
	<BlogArticle entry={entry} lang="en" />
</BaseLayout>
