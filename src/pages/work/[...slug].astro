---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import WorkArticle from '../../components/WorkArticle.astro';
import { localeOf, slugOf } from '../../i18n/ui';

interface Props {
	entry: CollectionEntry<'work'>;
}

// One page per English work entry. German entries are handled by src/pages/de/work/[...slug].astro.
export async function getStaticPaths() {
	const work = await getCollection('work');
	return work
		.filter((entry) => localeOf(entry.id) === 'en')
		.map((entry) => ({
			params: { slug: slugOf(entry.id) },
			props: { entry },
		}));
}

const { entry } = Astro.props;
---

<BaseLayout title={entry.data.title} description={entry.data.description} lang="en">
	<WorkArticle entry={entry} lang="en" />
</BaseLayout>
